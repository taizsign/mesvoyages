{% extends 'base.html.twig' %}

{% block title %}Nous contacter{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1>Contactez-nous</h1>

        {# Affichage du message de succès #}
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">
                {{ message }}
            </div>
        {% endfor %}

        <div class="card p-4 shadow-sm w-50 mt-4">
            {{ form_start(form) }}

            <div class="mb-3">
                {{ form_row(form.nom, {'attr': {'class': 'form-control', 'placeholder': 'Votre nom'}}) }}
            </div>

            <div class="mb-3">
                {{ form_row(form.email, {'attr': {'class': 'form-control', 'placeholder': 'Votre adresse email'}}) }}
            </div>

            <div class="mb-3">
                {{ form_row(form.message, {'attr': {'class': 'form-control', 'rows': 5, 'placeholder': 'Votre message...'}}) }}
            </div>

            {# On cache le champ date pour que l'utilisateur ne le voie pas #}
            {% do form.dateEnvoi.setRendered() %}

            <button type="submit" class="btn btn-primary mt-3">Envoyer</button>

            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
